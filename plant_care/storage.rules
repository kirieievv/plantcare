rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Plant images: users can read/write only their own folder
    match /plants/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Health check images: users can read/write only their own folder
    match /health_checks/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
