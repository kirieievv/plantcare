rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Watering events: user can only create/read their own events
    match /watering_events/{eventId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Allow read/write access to all documents for testing
    // WARNING: This is for development only - don't use in production!
    match /{document=**} {
      allow read, write: if true;
    }
    
    // For production, use more restrictive rules like:
    // match /plants/{plantId} {
    //   allow read, write: if request.auth != null;
    // }
  }
} 